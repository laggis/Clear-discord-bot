# Copy this file to .env and fill in your values

# Your Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=Your_Discord_Token_Here

# Comma-separated list of Discord user IDs that are Bot Admins
# These users can run /clear regardless of their server permissions
# Example: ADMIN_IDS=408659138030206990,1130574602033180734
ADMIN_IDS=
